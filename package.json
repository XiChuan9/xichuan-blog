{
  "name": "xichuan-blog",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:vercel": "XICHUAN_BLOG_RUNTIME=vercel next build --webpack",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "bash scripts/verify.sh full",
    "verify:quick": "bash scripts/verify.sh quick",
    "verify:vercel": "bash scripts/verify.sh vercel",
    "preview": "bash scripts/cf-preview.sh",
    "preview:remote": "PREVIEW_REMOTE=1 bash scripts/cf-preview.sh",
    "deploy": "bash scripts/cf-deploy.sh",
    "deploy:cloudflare": "bash scripts/cf-deploy.sh",
    "password:hash": "node scripts/hash-password.mjs",
    "worktree:add": "bash scripts/worktree-add.sh",
    "worktree:prune": "git worktree prune",
    "cf-typegen": "bash scripts/cf-typegen.sh",
    "cf:init": "bash scripts/cf-init.sh",
    "start": "next start",
    "lint": "eslint",
    "secret:scan": "bash scripts/secret-scan.sh"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-youtube": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tursodatabase/serverless": "^1.1.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/turndown": "^5.0.6",
    "@vercel/blob": "^2.3.3",
    "gray-matter": "^4.0.3",
    "html2pdf.js": "^0.14.0",
    "juice": "^11.1.1",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "novel": "^1.0.2",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "sanitize-html": "^2.17.3",
    "tiptap-extension-auto-joiner": "^0.1.3",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.13"
    }
  },
  "description": "Open-source Next.js blog starter with Cloudflare and Vercel runtimes, built-in themes, and AI provider presets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiChuan9/xichuan-blog.git"
  },
  "homepage": "https://github.com/XiChuan9/xichuan-blog",
  "bugs": {
    "url": "https://github.com/XiChuan9/xichuan-blog/issues"
  },
  "cloudflare": {
    "bindings": {
      "NEXT_PUBLIC_SITE_URL": {
        "description": "你的博客公网域名，例如 `https://blog.example.com`。"
      },
      "ADMIN_PASSWORD_HASH": {
        "description": "后台 `/admin` 登录密码哈希。用 `npm run password:hash -- \"your-password\"` 生成。"
      },
      "ADMIN_TOKEN_SALT": {
        "description": "管理员 Token 签名盐。可用 `openssl rand -hex 32` 生成。"
      },
      "AI_CONFIG_ENCRYPTION_SECRET": {
        "description": "用于加密保存 AI 供应商 Key。可用 `openssl rand -hex 32` 生成。"
      },
      "AI_API_KEY": {
        "description": "可选。外部 AI 服务的 API Key，用于文本生成或生图能力。"
      }
    }
  }
}
