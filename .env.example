# Generate with: npm run password:hash -- "your-admin-password"
ADMIN_PASSWORD_HASH=
ADMIN_TOKEN_SALT=change-me-to-a-random-string
AI_CONFIG_ENCRYPTION_SECRET=change-me-to-another-random-string
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel runtime
# Turso/libSQL keeps the existing SQLite/D1 query model.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Vercel Blob is used for uploads and generated media.
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_VERCEL_BLOB_ACCESS=public

# Optional external AI fallback
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Optional Cloudflare enhancements
ENABLE_BACKGROUND_JOBS=
ENABLE_WORKERS_AI=
ENABLE_VECTOR_SEARCH=
ENABLE_CF_IMAGE_PIPELINE=
ENABLE_PUBLIC_CACHE_IN_DEV=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
